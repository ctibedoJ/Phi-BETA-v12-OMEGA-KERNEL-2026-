        breakpoints=None
    else:
        print(">>> NO INPUT DETECTED. RUNNING GENESIS SIMULATION...")
        gen=GenesisEngine(d5); sequence, breakpoints=gen.construct_chromosome()
    
    experimental=None
    if args.exp:
        print(f">>> LOADING EXPERIMENTAL DATA: {args.exp}")
        experimental=np.loadtxt(args.exp)
    
    scanner=TitanScanner(sequence,d5)
    pos,res,ent,ten=scanner.run_scan(window_size=200,step=50)
    
    generate_dashboard(pos,res,ent,ten,sequence,experimental=experimental,bps=breakpoints,interactive=args.interactive)
